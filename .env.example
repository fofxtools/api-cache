# Database Configuration
DB_HOST=localhost
DB_DATABASE=api_cache_dev
DB_USERNAME=your_username
DB_PASSWORD=your_password

# API Cache Settings
API_CACHE_DEBUG=true

# Demo Client Settings
DEMO_API_URL=http://localhost:8000/demo-api.php
DEMO_API_CACHE_TTL=3600
DEMO_API_COMPRESSION_ENABLED=true
DEMO_API_COMPRESSION_LEVEL=6
DEMO_API_RATE_LIMIT_WINDOW=60
DEMO_API_RATE_LIMIT_MAX=5

# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CACHE_TTL=-1
OPENAI_COMPRESSION_ENABLED=false
OPENAI_DEFAULT_ENDPOINT=chat/completions
OPENAI_RATE_LIMIT_WINDOW=60
OPENAI_RATE_LIMIT_MAX=60

# Pixabay Configuration
PIXABAY_API_KEY=...
PIXABAY_BASE_URL=https://pixabay.com/api
PIXABAY_CACHE_TTL=-1
PIXABAY_COMPRESSION_ENABLED=false
PIXABAY_DEFAULT_ENDPOINT=search
PIXABAY_RATE_LIMIT_WINDOW=60
PIXABAY_RATE_LIMIT_MAX=100